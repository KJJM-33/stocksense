# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 1 only: the single household /tap writes to.
# Get this by running the one-time insert at the bottom of supabase/schema.sql,
# then pasting the returned id here.
NEXT_PUBLIC_DEFAULT_HOUSEHOLD_ID=

# Anthropic (vision scan, receipt parsing, WhatsApp NL) — server-side only, never exposed to the client
ANTHROPIC_API_KEY=

# Twilio (WhatsApp/SMS) — server-side only, never exposed to the client
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Deployed app URL, used to build NFC tag URLs and links in outbound messages
NEXT_PUBLIC_APP_URL=http://localhost:3000
